generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id               String        @id @default(uuid())
  email            String        @unique
  passwordHash     String
  twoFactorSecret  String?
  twoFactorEnabled Boolean       @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  actions          AdminAction[]

  @@map("admins")
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  note       String?
  createdAt  DateTime @default(now())
  admin      Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_actions")
}

model TenantApp {
  id          String              @id @default(uuid())
  name        String
  email       String              @unique
  webhookUrl  String?
  status      TenantStatus        @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  apiKeys     ApiKey[]
  batches     DisbursementBatch[]
  webhookLogs WebhookLog[]

  @@map("tenant_apps")
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model ApiKey {
  id        String       @id @default(uuid())
  tenantId  String
  key       String       @unique
  status    ApiKeyStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  revokedAt DateTime?
  tenant    TenantApp    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model DisbursementBatch {
  id             String            @id @default(uuid())
  tenantId       String
  idempotencyKey String?
  userPseudoId   String
  senderPhone    String
  totalAmount    Int
  totalCharges   Int
  chargeReceiver String
  status         BatchStatus       @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         TenantApp         @relation(fields: [tenantId], references: [id])
  jobs           DisbursementJob[]
  webhookLogs    WebhookLog[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([idempotencyKey])
  @@index([userPseudoId])
  @@index([senderPhone])
  @@index([status])
  @@map("disbursement_batches")
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIALLY_FAILED
}

model DisbursementJob {
  id         String            @id @default(uuid())
  batchId    String
  phone      String
  amount     Int
  jobType    JobType
  status     JobStatus         @default(QUEUED)
  mtnRef     String?
  failReason String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  batch      DisbursementBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([status])
  @@map("disbursement_jobs")
}

enum JobType {
  PAYOUT
  CHARGE
}

enum JobStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
}

model WebhookLog {
  id            String            @id @default(uuid())
  batchId       String
  tenantId      String
  url           String
  payload       Json
  status        WebhookStatus     @default(PENDING)
  attempts      Int               @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  batch         DisbursementBatch @relation(fields: [batchId], references: [id])
  tenant        TenantApp         @relation(fields: [tenantId], references: [id])

  @@index([batchId])
  @@index([tenantId])
  @@index([status])
  @@map("webhook_logs")
}

enum WebhookStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}
