# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql://momo:secret@localhost:5432/momo_db?schema=public
POSTGRES_USER=momo
POSTGRES_PASSWORD=secret
POSTGRES_DB=momo_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# MTN MoMo
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your_subscription_key
MTN_API_USER=your_api_user
MTN_API_KEY=your_api_key
MTN_ENVIRONMENT=sandbox
MTN_CALLBACK_URL=https://yourdomain.com/mtn-callback

# Seeding
RUN_SEED=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=60